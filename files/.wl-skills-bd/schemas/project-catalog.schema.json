{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agile-team.example/schemas/wl-backend-project-catalog-v1.json",
  "title": "wl-skills-bd project catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "project", "modules", "relationships", "stats", "diagnostics", "catalogHash"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "wl-backend-project-catalog" },
    "project": { "type": "object" },
    "modules": { "type": "array" },
    "relationships": { "type": "array" },
    "stats": { "type": "object" },
    "diagnostics": { "type": "object" },
    "catalogHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
