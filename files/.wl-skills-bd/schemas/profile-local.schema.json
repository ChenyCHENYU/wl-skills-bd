{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agile-team.example/schemas/wl-profile-local-v1.json",
  "title": "wl-skills-bd project-local profile override",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "profileId"],
  "anyOf": [
    { "required": ["softDelete"] },
    { "required": ["auditTime"] }
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "profileId": { "type": "string", "minLength": 1 },
    "softDelete": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "column": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,62}$" },
        "javaField": { "const": "isDelete" },
        "activeValue": { "type": "integer" },
        "deletedValue": { "type": "integer" },
        "mysqlType": { "enum": ["TINYINT(1)", "INT"] },
        "oracleType": { "type": "string", "pattern": "^NUMBER\\([1-9]\\)$" }
      }
    },
    "auditTime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mysqlType": { "type": "string", "pattern": "^(VARCHAR\\(19\\)|DATETIME(\\([0-6]\\))?)$" },
        "oracleType": { "type": "string", "pattern": "^(VARCHAR2\\(19 CHAR\\)|TIMESTAMP(\\([0-9]\\))?)$" }
      }
    }
  }
}
