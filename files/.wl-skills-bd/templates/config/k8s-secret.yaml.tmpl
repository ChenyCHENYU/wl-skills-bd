# K8s Secret 模板（L2 部署侧）— 由 wl-skills-bd config migrate 生成 .example
# ⚠️ 本文件是 .example，实际值由运维人工填充后部署，绝不进 git
# 客户：{{customer}} | 环境：{{env}}
apiVersion: v1
kind: Secret
metadata:
  name: {{project}}-secret
  namespace: {{k8sNamespace}}
  labels:
    app: {{project}}
    customer: {{customer}}
    env: {{env}}
type: Opaque
stringData:
  NACOS_PASSWORD: "***CHANGE_ME***"
  DB_PASSWORD: "***CHANGE_ME***"
  REDIS_PASSWORD: "***CHANGE_ME***"
