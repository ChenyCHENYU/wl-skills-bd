# bootstrap.yml（L1 环境无关骨架）— 由 wl-skills-bd config init 生成
# 铁律：全 ${VAR} 占位，零硬编码敏感信息（standards/25 §1.2）
spring:
  application:
    name: ${APP_NAME:{{project}}}
  main:
    allow-bean-definition-overriding: true
  cloud:
    nacos:
      config:
        server-addr: ${NACOS_HOST}
        file-extension: yml
        group: JH4J
        shared-configs:
          - dataId: application-${spring.profiles.active}.${spring.cloud.nacos.config.file-extension}
            group: ${spring.cloud.nacos.config.group}
          - dataId: datasource-${DATASOURCE:{{datasourceType}}}-${spring.profiles.active}.${spring.cloud.nacos.config.file-extension}
            group: ${spring.cloud.nacos.config.group}
          - dataId: redis-${spring.profiles.active}.${spring.cloud.nacos.config.file-extension}
            group: ${spring.cloud.nacos.config.group}
            refresh: true
        namespace: ${NACOS_CONFIG_NAMESPACE}
        username: ${NACOS_USERNAME}
        password: ${NACOS_PASSWORD}
      discovery:
        server-addr: ${spring.cloud.nacos.config.server-addr}
        group: ${spring.cloud.nacos.config.group}
        namespace: ${NACOS_DISCOVERY_NAMESPACE}
        username: ${spring.cloud.nacos.config.username}
        password: ${spring.cloud.nacos.config.password}
  profiles:
    active: ${PROFILES_ACTIVE:dev}
