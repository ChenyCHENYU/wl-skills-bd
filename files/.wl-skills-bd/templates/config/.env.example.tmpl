# .env.{{env}}.example（L2 环境变量层）— 由 wl-skills-bd config init/migrate 生成
# 部署侧填充实际值；本文件进 git（.example），实际 .env.{env} 不进 git
# 详见 standards/25 §1.3

# ===== Spring Profile =====
PROFILES_ACTIVE={{env}}

# ===== 应用 =====
APP_NAME={{project}}
SERVER_PORT={{port}}

# ===== Nacos =====
NACOS_HOST={{nacosHost}}
NACOS_USERNAME={{nacosUsername}}
NACOS_PASSWORD=***CHANGE_ME***
NACOS_CONFIG_NAMESPACE={{nacosNamespace}}
NACOS_DISCOVERY_NAMESPACE={{nacosNamespace}}

# ===== DataSource =====
DATASOURCE={{datasourceType}}
DB_HOST={{dbHost}}
DB_PORT={{dbPort}}
DB_SID={{dbSid}}
DB_USERNAME={{dbUsername}}
DB_PASSWORD=***CHANGE_ME***

# ===== Redis =====
REDIS_HOST={{redisHost}}
REDIS_PORT={{redisPort}}
REDIS_PASSWORD=***CHANGE_ME***

# ===== OpenAPI（生产关闭）=====
{{#isProd}}
SPRINGDOC_ENABLED=false
SPRINGDOC_UI_ENABLED=false
KNIFE4J_PRODUCTION=true
{{/isProd}}
{{^isProd}}
SPRINGDOC_ENABLED=true
SPRINGDOC_UI_ENABLED=true
KNIFE4J_PRODUCTION=false
{{/isProd}}
