<?xml version="1.0" encoding="UTF-8"?>
<!--
  {{Entity}}Mapper.xml — {{apiDesc}}的 SQL 映射
  namespace 必须与 Mapper.java 全限定名一致
  规则：禁 SELECT 星号 / 禁 ${} 注入 / 软删除条件常驻（standards/06）
-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="{{rootPackage}}.{{module}}.mapper.{{Entity}}Mapper">

    <!-- 显式列出字段，禁止 SELECT *（standards/06）-->
    <sql id="BaseColumns">
        t.ID               AS id,
        {{#columns}}
        t.{{COLUMN}}            AS {{field}},
        {{/columns}}
        t.COMPANY_ID       AS companyId,
        t.IS_DELETE        AS isDelete,
        t.REVISION         AS revision,
        t.CREATE_USER_NO   AS createUserNo,
        t.CREATE_DATE_TIME AS createDateTime,
        t.UPDATE_USER_NO   AS updateUserNo,
        t.UPDATE_DATE_TIME AS updateDateTime
    </sql>

    <!-- 分页查询：动态条件 + 软删除常驻 -->
    <select id="queryPage" resultType="{{rootPackage}}.api.vo.{{module}}.{{Entity}}PageVO">
        SELECT
        <include refid="BaseColumns"/>
        FROM {{table}} t
        <where>
            <!-- 软删除条件常驻（standards/06：IS_DELETE = 1 有效）-->
            AND t.IS_DELETE = 1
            <!-- 租户值只能由 Service 从 AuthUtil 注入，禁止从请求 DTO 获取 -->
            AND t.COMPANY_ID = #{companyId}
            <if test="param != null">
                {{#queryConditions}}
                <if test="param.{{field}} != null and param.{{field}} != ''">
                    AND t.{{COLUMN}} = #{param.{{field}}}
                </if>
                {{/queryConditions}}
                {{#likeConditions}}
                <if test="param.{{field}} != null and param.{{field}} != ''">
                    <!-- Oracle CONCAT 仅支持2参数，三参数要嵌套（standards/06）-->
                    AND t.{{COLUMN}} LIKE CONCAT(CONCAT('%', #{param.{{field}}}), '%')
                </if>
                {{/likeConditions}}
            </if>
        </where>
        ORDER BY t.CREATE_DATE_TIME DESC
    </select>

    <!-- 按 ID + 租户查询详情（用于复杂详情联表场景的起点；默认 getById 由 Service.lambdaQuery 兜底） -->
    <select id="queryById" resultType="{{rootPackage}}.api.vo.{{module}}.{{Entity}}VO">
        SELECT
        <include refid="BaseColumns"/>
        FROM {{table}} t
        WHERE t.IS_DELETE = 1
          AND t.COMPANY_ID = #{companyId}
          AND t.ID = #{id}
    </select>

    <!-- 所有业务更新必须在同一条 SQL 中同时约束 ID、租户、有效标记和版本号。 -->
    <update id="updateAtomic">
        UPDATE {{table}}
        <set>
            {{#columns}}
            <if test="entity.{{field}} != null">
                {{COLUMN}} = #{entity.{{field}}},
            </if>
            {{/columns}}
            UPDATE_USER_NO = #{entity.updateUserNo},
            UPDATE_DATE_TIME = #{entity.updateDateTime},
            REVISION = REVISION + 1
        </set>
        WHERE ID = #{entity.id}
          AND COMPANY_ID = #{companyId}
          AND IS_DELETE = 1
          AND REVISION = #{expectedRevision}
    </update>

    <!-- 团队软删除口径：1=有效、0=删除；禁止物理 DELETE。 -->
    <update id="softDeleteAtomic">
        UPDATE {{table}}
        SET IS_DELETE = 0,
            UPDATE_USER_NO = #{entity.updateUserNo},
            UPDATE_DATE_TIME = #{entity.updateDateTime},
            REVISION = REVISION + 1
        WHERE ID = #{entity.id}
          AND COMPANY_ID = #{companyId}
          AND IS_DELETE = 1
          AND REVISION = #{entity.revision}
    </update>

</mapper>
