  "customOperations": [
    {
      "name": "submit",
      "summary": "提交审批",
      "method": "POST",
      "path": "submit/{id}",
      "permission": "sale_order_master_submit",
      "kind": "stateTransition",
      "preconditions": [
        { "field": "status", "operator": "equals", "value": "DRAFT", "message": "仅草稿状态可提交" }
      ],
      "patch": [{ "field": "status", "value": "SUBMITTED" }],
      "externalId": "OP_SUBMIT"
    },
    {
      "name": "approve",
      "summary": "审批通过",
      "method": "POST",
