      "requestFields": [
        { "name": "opinion", "javaType": "String", "comment": "审批意见", "required": false, "maxLength": 500 }
      ],
      "preconditions": [
        { "field": "status", "operator": "equals", "value": "SUBMITTED", "message": "仅已提交可审批" }
      ],
      "patch": [
        { "field": "status", "value": "APPROVED" },
        { "field": "approvalOpinion", "fromRequest": "opinion" }
      ],
      "externalId": "OP_APPROVE"
    },
    {
      "name": "batchCancel",
      "summary": "批量作废",
      "method": "POST",
      "path": "batchCancel",
      "permission": "sale_order_master_batch_cancel",
      "kind": "batch",
      "preconditions": [
        { "field": "status", "operator": "in", "value": ["DRAFT", "SUBMITTED"], "message": "仅草稿/已提交可作废" }
      ],
      "patch": [{ "field": "status", "value": "CANCELLED" }],
      "externalId": "OP_BATCH_CANCEL"
    }
  ],
