<?xml version="1.0" encoding="UTF-8"?>
<!--
  wl-skills-bd 阿里 P3C 规则集（J6 · 社区最佳实践机器卡控）
  对应 standards/19-design + 补全 03/15/16/17 未穷举的社区规则

  规则来源：com.alibaba.p3c:p3c-pmd:2.1.1（54 条规则，黄山版）

  接入要点（见同目录 README.md）：
    1. pom.xml 的 maven-pmd-plugin 加 p3c-pmd 依赖到 <dependencies>
    2. <rulesets> 引用 rulesets/java/ali-*.xml（P3C jar 内置路径）
       或本文件作为自定义 ruleset 引入 ali-* 子集

  本文件采用"分类引入 P3C 子规则集"方式，便于按需启用/排除
-->
<ruleset name="wl-skills-bd-ali-p3c"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

  <description>
    阿里巴巴黄山版 Java 开发手册 P3C 实现（54 条规则的精选子集）。
    依据：《Java 开发手册（黄山版）》第七章设计规约 + 第一~六章高频强制项。
  </description>

  <!-- ════════ 一、命名规约（对应 standards/03 + 19）════════ -->

  <!-- 全量引用阿里命名规则集 -->
  <rule ref="rulesets/java/ali-naming.xml">
    <!-- 排除：团队基线 Service 不强制 Impl 后缀（直继 JhServiceImpl，无独立接口）-->
    <exclude name="AbstractClassShouldStartWithAbstractNamingRule"/>
  </rule>

  <!-- ════════ 二、常量规约（对应 standards/15 R10/R18）════════ -->

  <rule ref="rulesets/java/ali-constant.xml"/>

  <!-- ════════ 三、OOP 规约（对应 standards/15 + 17）════════ -->

  <rule ref="rulesets/java/ali-oop.xml">
    <!-- POJO 禁默认值：团队 Entity 继承 CoreEntity，部分字段有默认值是基线设计，排除 -->
    <exclude name="PojoMustOverrideToStringRule"/>
  </rule>

  <!-- ════════ 四、集合规约（对应 standards/16/17，补全 bd 未覆盖）════════ -->

  <rule ref="rulesets/java/ali-set.xml"/>

  <!-- ════════ 五、并发规约（对应 standards/17 R08/R40/R43）════════ -->

  <rule ref="rulesets/java/ali-concurrent.xml"/>

  <!-- ════════ 六、控制语句（对应 standards/15 R12/R15/R20）════════ -->

  <rule ref="rulesets/java/ali-flowcontrol.xml"/>

  <!-- ════════ 七、异常规约（对应 standards/08）════════ -->

  <rule ref="rulesets/java/ali-exception.xml"/>

  <!-- ════════ 八、注释规约（对应 standards/19 §9 + 15）════════ -->

  <rule ref="rulesets/java/ali-comment.xml"/>

  <!-- ════════ 九、其他（正则预编译/时间获取/日期格式 y）════════ -->

  <rule ref="rulesets/java/ali-other.xml"/>

  <!-- ════════ 十、MySQL/ORM 规约（对应 standards/12）════════ -->

  <rule ref="rulesets/java/ali-orm.xml"/>

  <!-- ════════ 设计级补充（PMD 内置 + 与 19-design 联动）════════ -->

  <!-- 方法长度 ≤ 80 行（阿里手册 + standards/15 R14 + 19 §3）-->
  <rule ref="category/java/codestyle.xml/ExcessiveMethodLength">
    <properties>
      <property name="minimum" value="80"/>
    </properties>
  </rule>

  <!-- 参数个数 ≤ 5（standards/19 §3）-->
  <rule ref="category/java/codestyle.xml/ExcessiveParameterList">
    <properties>
      <property name="minimum" value="5"/>
    </properties>
  </rule>

  <!-- 圈复杂度（standards/19 §3，B11 启发式补充）-->
  <rule ref="category/java/design.xml/CyclomaticComplexity">
    <properties>
      <property name="methodReportLevel" value="10"/>
      <property name="classReportLevel" value="100"/>
    </properties>
  </rule>

  <!-- 类长度 / God Class 检测（standards/19 §3，B9 兜底）-->
  <rule ref="category/java/design.xml/ExcessiveClassLength">
    <properties>
      <property name="minimum" value="500"/>
    </properties>
  </rule>

  <!-- 过深嵌套（standards/19 §3 卫语句）-->
  <rule ref="category/java/design.xml/ExcessiveNestingDepth">
    <properties>
      <property name="minimum" value="3"/>
    </properties>
  </rule>

  <!-- 上帝类检测（耦合度过高，standards/19 §6）-->
  <rule ref="category/java/design.xml/GodClass"/>

</ruleset>
