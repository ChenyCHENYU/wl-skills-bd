<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  wl-skills-bd Checkstyle 规则集（J2）
  对应 standards/03-naming + standards/15-code-quality

  接入：见同目录 README.md
  基于官方 sun_checks.xml 裁剪，贴合 jh4j-cloud + MyBatis-Plus 技术栈
-->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="error"/>
  <property name="fileExtensions" value="java, properties, xml"/>

  <!-- 排除生成代码（MyBatis-Plus / Lombok）-->
  <module name="BeforeExecutionExclusionFileFilter">
    <property name="exclusionPattern" value="[\\/]target[\\/]|generated-sources"/>
  </module>

  <module name="FileTabCharacter">
    <property name="eachLine" value="true"/>
    <message key="containsTab" value="禁止 Tab，统一用空格缩进"/>
  </module>

  <module name="TreeWalker">
    <!-- ===== standards/03 命名 ===== -->

    <!-- 类名：PascalCase + 业务后缀（Controller/Service/ServiceImpl/Mapper/Enum/Constants）-->
    <module name="TypeName">
      <property name="format"
                value="^([A-Z][a-z0-9]+)+$|^([A-Z][a-z0-9]+)+(Controller|Service|ServiceImpl|Mapper|Enum|Constants|DTO|VO|Query|Entity|Config|Test|Job|Listener|Aspect)$"/>
      <message key="name.invalidPattern"
               value="类名须 PascalCase；Controller/Service/Mapper 等须有标准后缀（standards/03）"/>
    </module>

    <!-- 方法名 camelCase；CRUD 动词遵循 standards/03 R05 -->
    <module name="MethodName">
      <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
    </module>

    <!-- 常量 UPPER_SNAKE_CASE -->
    <module name="ConstantName">
      <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
    </module>

    <!-- 包名全小写，无下划线（standards/03 R01）-->
    <module name="PackageName">
      <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
    </module>

    <!-- 局部变量 / 参数 camelCase -->
    <module name="LocalVariableName"/>
    <module name="ParameterName"/>
    <module name="MemberName"/>

    <!-- ===== standards/15 代码质量 ===== -->

    <!-- 未用 import（standards/15 R21，AI 生成代码高发）-->
    <module name="UnusedImports"/>

    <!-- 禁 import 通配符 * -->
    <module name="AvoidStarImport"/>

    <!-- 大括号强制（if/else/for/while 都要大括号，standards/15）-->
    <module name="NeedBraces"/>

    <!-- 空语句块要有说明 -->
    <module name="EmptyBlock"/>

    <!-- 方法长度 ≤ 80 行（standards/15 建议方法精简）-->
    <module name="MethodLength">
      <property name="max" value="80"/>
      <property name="countEmpty" value="false"/>
    </module>

    <!-- 参数个数 ≤ 5（过多考虑封装 DTO）-->
    <module name="ParameterNumber">
      <property name="max" value="5"/>
    </module>

    <!-- 一行 ≤ 150 字符 -->
    <module name="LineLength">
      <property name="max" value="150"/>
      <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
    </module>

    <!-- 魔法数字（常量提取，standards/15）-->
    <module name="MagicNumber">
      <property name="ignoreNumbers" value="-1, 0, 1, 2"/>
      <property name="ignoreAnnotation" value="true"/>
    </module>

    <!-- ===== 杂项 ===== -->
    <!-- import 顺序：先 java/javax，再第三方，再自己的 -->
    <module name="ImportOrder">
      <property name="groups" value="java,javax,org,com"/>
      <property name="ordered" value="true"/>
      <property name="separated" value="true"/>
      <property name="option" value="above"/>
      <property name="sortStaticImportsAlphabetically" value="true"/>
    </module>

    <module name="RedundantImport"/>

    <!-- 缩进：4 空格 -->
    <module name="RegexpSinglelineJava">
      <property name="format" value="^\t* "/>
      <property name="message" value="缩进用 4 空格，混合缩进禁止"/>
      <property name="ignoreComments" value="true"/>
    </module>
  </module>
</module>
